# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual envs
.venv

# Secrets
.env
.env.*
!.env.example

# Logs / runtime data
logs/
*.log

# Markout tables: rebuilt locally on each host from rolling captures.
# Operator must build via `scripts/build_markout_table.py` before first
# live launch. The directory is kept (via .gitkeep); only the *.json
# content is host-specific.
configs/markout/*.json

# Docs (host-local, not tracked)
docs/

# Claude Code (host-local)
CLAUDE.md

# IDE
.idea/
.vscode/
.DS_Store
